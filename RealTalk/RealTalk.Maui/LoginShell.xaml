<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RealTalk.Maui.LoginShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RealTalk.Maui.Views"
    Title="Login">

    <!--<ShellContent Title="Login" ContentTemplate="{DataTemplate views:LoginPage}" Route="LoginPage" />-->

    <TabBar>
        <Tab Title="Login">
            <ShellContent Title="Login" ContentTemplate="{DataTemplate views:LoginPage}" Route="LoginPage" />
        </Tab>

        <Tab Title="Register">
            <ShellContent Title="Register" ContentTemplate="{DataTemplate views:RegisterPage}" Route="RegisterPage" />
        </Tab>
    </TabBar>

</Shell>
